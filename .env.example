# DeVoice 站点基础地址，生产环境请填写正式域名。
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# NextAuth 加密密钥，生产环境请使用 openssl rand -base64 32 生成。
NEXTAUTH_SECRET=""
NEXTAUTH_URL="http://localhost:3000"

# Google OAuth：在 Google Cloud Console 创建 Web OAuth Client 后填写。
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# 可选的本地 DeVoice 邮箱密码演示登录。不要提交真实生产密码。
DEVOICE_DEMO_EMAIL=""
DEVOICE_DEMO_PASSWORD=""

# 密码重置邮件发送。未配置 RESEND_API_KEY 时，开发环境会返回预览重置链接。
RESEND_API_KEY=""
EMAIL_FROM="DeVoice <noreply@devoice.io>"
PASSWORD_RESET_TOKEN_TTL_MINUTES="30"

# TiDB Cloud 连接串示例：
# mysql://USER:PASSWORD@gateway01.REGION.prod.aws.tidbcloud.com:4000/DATABASE?sslaccept=strict
DATABASE_URL=""

# Upstash Redis REST API 配置。
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# BullMQ 需要 Redis TCP 连接串。Upstash 请复制 rediss:// 开头的 Redis URL。
REDIS_URL=""
DEVOICE_QUEUE_NAME="devoice-media-jobs"
DEVOICE_WORKER_CONCURRENCY="3"
DEVOICE_DISABLE_BULLMQ="false"
DEVOICE_QUEUE_CONNECT_TIMEOUT_MS="3000"
DEVOICE_QUEUE_COMMAND_TIMEOUT_MS="3000"
DEVOICE_QUEUE_CIRCUIT_BREAKER_MS="60000"

# Cloudflare R2 对象存储。R2_ENDPOINT 示例：https://<account-id>.r2.cloudflarestorage.com
R2_ENDPOINT=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET=""
R2_PUBLIC_BASE_URL=""
R2_WORKER_DOWNLOAD_EXPIRES_IN="1800"

# 本地/服务器 ffmpeg 路径。用于 TTS MP3 转码，以及 Remove Background Noise 的真实媒体清理 WAV 导出。
FFMPEG_PATH="ffmpeg"

# OpenAI Speech API。配置后 Text to Speech / AI Voice Cloning 会优先生成真实 MP3/WAV 音频。
# 如果同时配置 R2，任务完成时会持久化生成的 MP3 artifact，后续下载会优先复用。
# 未配置或调用失败时自动回退到本地 DeVoice 预览音频。
OPENAI_API_KEY=""
OPENAI_TTS_MODEL="gpt-4o-mini-tts"
OPENAI_TTS_VOICE=""
OPENAI_TTS_FALLBACK_VOICE="alloy"
OPENAI_TTS_TIMEOUT_MS="60000"
OPENAI_TTS_MAX_CHARS="4096"

# ElevenLabs Instant Voice Cloning。配置后 AI Voice Cloning 会使用上传样本创建临时克隆声音，
# 再生成 MP3 结果。Remove Background Noise 也会优先使用 ElevenLabs Audio Isolation。
# 如果同时配置 R2，生成结果会持久化并被后续下载复用。
ELEVENLABS_API_KEY=""
ELEVENLABS_BASE_URL="https://api.elevenlabs.io"
ELEVENLABS_TTS_MODEL="eleven_multilingual_v2"
ELEVENLABS_OUTPUT_FORMAT="mp3_44100_128"
ELEVENLABS_TIMEOUT_MS="120000"
ELEVENLABS_TTS_MAX_CHARS="5000"
ELEVENLABS_AUDIO_ISOLATION_TIMEOUT_MS="180000"

# 语音识别与转写服务商，worker 会按 Deepgram -> AssemblyAI -> Groq 的顺序降级。
DEEPGRAM_API_KEY=""
ASSEMBLYAI_API_KEY=""
ASSEMBLYAI_MAX_POLLS="30"
ASSEMBLYAI_POLL_INTERVAL_MS="3000"
GROQ_API_KEY=""
GROQ_TRANSCRIBE_MODEL="whisper-large-v3-turbo"
GROQ_MEDIA_FETCH_TIMEOUT_MS="120000"
GROQ_TRANSCRIBE_TIMEOUT_MS="180000"

# YouTube 字幕/转写兜底服务。YouTube timedtext 无公开字幕时，系统会调用该 JSON API。
# POST body: { url, videoId, language, sourceType }；GET 模式会把这些字段放入 query string。
# 返回可包含 transcript/text、srt/subtitles、cues/segments、summary/chapters/keywords。
YOUTUBE_TRANSCRIPT_API_URL=""
YOUTUBE_TRANSCRIPT_API_KEY=""
YOUTUBE_TRANSCRIPT_API_KEY_HEADER=""
YOUTUBE_TRANSCRIPT_API_METHOD="POST"
YOUTUBE_TRANSCRIPT_TIMEOUT_MS="120000"

# 摘要、章节、关键词等生成模型，worker 会按 DeepSeek -> Gemini 的顺序降级。
DEEPSEEK_API_KEY=""
DEEPSEEK_BASE_URL="https://api.deepseek.com/chat/completions"
DEEPSEEK_MODEL="deepseek-v4"
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-2.5-flash"

# 翻译服务商，系统会按 DeepL -> deepseek-v4-flash 的顺序降级。
DEEPL_API_KEY=""
DEEPL_API_URL="https://api-free.deepl.com/v2/translate"
DEEPSEEK_TRANSLATE_MODEL="deepseek-v4-flash"

# 商业化支付预留。当前数据模型已支持订阅状态和用量事件，接 Stripe 后填写。
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
STRIPE_ENTRY_PRICE_ID=""
STRIPE_STANDARD_PRICE_ID=""
STRIPE_COMPREHENSIVE_PRICE_ID=""
STRIPE_ELITE_CREDITS_PRICE_ID=""
STRIPE_BASIC_PRICE_ID=""
STRIPE_PRO_PRICE_ID=""
STRIPE_ELITE_SUBSCRIPTION_PRICE_ID=""
STRIPE_CREDIT_PACKAGE_PRICE_ID=""
